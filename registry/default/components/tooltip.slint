// slintcn Tooltip — hover-revealed bubble using Slint's PopupWindow.
//
// Usage:
//   Tooltip {
//       text: "Save and continue";
//       side: TooltipSide.top;
//       Button { text: "Save"; }
//   }
//
// PopupWindow lets the bubble render on a layer above the parent window,
// so the trigger can sit anywhere inside a deeply nested layout without
// the bubble being clipped by its surrounding component. (The popup is
// still bounded by the parent Window's edges — for near-edge triggers the
// `side` prop chooses which way to lean.)
//
// Implementation notes:
//   - Slint's PopupWindow is shown/closed imperatively via .show() /
//     .close(). We watch a computed `trigger-hovered` property via the
//     `changed` callback and call show/close accordingly.
//   - PopupWindow positions itself at (x, y) relative to its parent
//     element (Tooltip). We pre-compute bubble dimensions so we can
//     anchor by side without measuring asynchronously.
//   - close-policy: no-auto-close — the popup is driven by hover state,
//     not by user clicks.

import { Tokens } from "../theme/tokens.slint";

export enum TooltipSide { top, right, bottom, left }

export component Tooltip {
    in property <string> text;
    in property <TooltipSide> side: TooltipSide.top;

    property <length> bubble-width:  measure-text.preferred-width  + 16px;
    property <length> bubble-height: measure-text.preferred-height + 8px;

    trigger-area := TouchArea { }
    @children

    // Hidden Text used only to measure the popup's preferred size. Sized
    // 0×0 so it doesn't affect layout; we just read preferred-width/height.
    measure-text := Text {
        x: 0;
        y: 0;
        width:  0;
        height: 0;
        text: root.text;
        font-size: Tokens.typography-body-sm-size;
        visible: false;
    }

    property <bool> trigger-hovered: trigger-area.has-hover;
    changed trigger-hovered => {
        if (self.trigger-hovered) { popup.show(); }
        else                       { popup.close(); }
    }

    popup := PopupWindow {
        close-policy: no-auto-close;

        x: side == TooltipSide.left
            ? -root.bubble-width - 8px :
           side == TooltipSide.right
            ? parent.width + 8px :
           /* top | bottom */
            (parent.width - root.bubble-width) / 2;

        y: side == TooltipSide.top
            ? -root.bubble-height - 8px :
           side == TooltipSide.bottom
            ? parent.height + 8px :
           /* left | right */
            (parent.height - root.bubble-height) / 2;

        width:  root.bubble-width;
        height: root.bubble-height;

        Rectangle {
            background: Tokens.color-card;
            border-color: Tokens.color-border-hairline-strong;
            border-width: 1px;
            border-radius: Tokens.radius-md;
            drop-shadow-blur:     Tokens.shadow-e2-blur;
            drop-shadow-offset-y: Tokens.shadow-e2-offset-y;
            drop-shadow-color:    Tokens.shadow-e2-color;

            Text {
                x: 8px;
                y: 4px;
                text: root.text;
                color: Tokens.color-foreground;
                font-size: Tokens.typography-body-sm-size;
            }
        }
    }
}
