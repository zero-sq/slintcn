{
  "_comment": "Behavior/accessibility contract per item — surfaced in docs + merged into `slintcn export`/`build` output so consumers (e.g. a generated design-system spec) can adopt the keyboard/focus semantics, not just the visuals.",
  "button":            { "focusable": true,  "keyboard": ["Enter", "Space"], "focusTrap": false, "escapeDismiss": false },
  "input":             { "focusable": true,  "keyboard": ["text entry"],     "focusTrap": false, "escapeDismiss": false },
  "textarea":          { "focusable": true,  "keyboard": ["text entry"],     "focusTrap": false, "escapeDismiss": false },
  "checkbox":          { "focusable": true,  "keyboard": ["Space"],          "focusTrap": false, "escapeDismiss": false },
  "switch":            { "focusable": true,  "keyboard": ["Space"],          "focusTrap": false, "escapeDismiss": false },
  "toggle":            { "focusable": true,  "keyboard": ["Enter", "Space"], "focusTrap": false, "escapeDismiss": false },
  "toggle-group":      { "focusable": true,  "keyboard": ["Enter", "Space"], "focusTrap": false, "escapeDismiss": false },
  "radio-group":       { "focusable": true,  "keyboard": ["Arrow keys", "Space"], "focusTrap": false, "escapeDismiss": false },
  "select":            { "focusable": true,  "keyboard": ["Enter", "Space"], "focusTrap": false, "escapeDismiss": true },
  "slider":            { "focusable": true,  "keyboard": ["Arrow keys"],     "focusTrap": false, "escapeDismiss": false },
  "tabs":              { "focusable": true,  "keyboard": ["Arrow keys"],     "focusTrap": false, "escapeDismiss": false },
  "accordion":         { "focusable": true,  "keyboard": ["Enter", "Space"], "focusTrap": false, "escapeDismiss": false },
  "pagination":        { "focusable": true,  "keyboard": ["Enter"],          "focusTrap": false, "escapeDismiss": false },
  "dialog":            { "focusable": true,  "keyboard": ["Tab", "Escape"],  "focusTrap": true,  "escapeDismiss": true },
  "dialog-panel":      { "focusable": true,  "keyboard": ["Tab", "Escape"],  "focusTrap": true,  "escapeDismiss": true },
  "alert-dialog":      { "focusable": true,  "keyboard": ["Tab", "Escape"],  "focusTrap": true,  "escapeDismiss": true },
  "alert-dialog-panel":{ "focusable": true,  "keyboard": ["Tab", "Escape"],  "focusTrap": true,  "escapeDismiss": true },
  "sheet":             { "focusable": true,  "keyboard": ["Escape"],         "focusTrap": false, "escapeDismiss": true },
  "popover":           { "focusable": true,  "keyboard": ["Escape"],         "focusTrap": false, "escapeDismiss": true },
  "context-menu":      { "focusable": true,  "keyboard": ["Escape"],         "focusTrap": false, "escapeDismiss": true },
  "tooltip":           { "focusable": false, "keyboard": [],                 "focusTrap": false, "escapeDismiss": false },
  "dropdown-menu":     { "focusable": true,  "keyboard": ["Arrow keys", "Enter"], "focusTrap": false, "escapeDismiss": true  },
  "menubar":           { "focusable": true,  "keyboard": ["Arrow keys", "Enter"], "focusTrap": false, "escapeDismiss": true  },
  "navigation-menu":   { "focusable": true,  "keyboard": ["Arrow keys", "Enter"], "focusTrap": false, "escapeDismiss": false },
  "hover-card":        { "focusable": false, "keyboard": [],                 "focusTrap": false, "escapeDismiss": false },
  "combobox":          { "focusable": true,  "keyboard": ["text entry", "Enter"], "focusTrap": false, "escapeDismiss": false },
  "command":           { "focusable": true,  "keyboard": ["text entry", "Enter"], "focusTrap": false, "escapeDismiss": false }
}
