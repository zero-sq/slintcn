// Bundled Lucide path commands — copy-paste constants for the Icon component.
// All paths are 24-unit viewBox, stroked (stroke-width 2 reads cleanly).
//
// Source: https://lucide.dev (ISC license, see icons.lucide.dev).
// To add more, transcribe the `d=` attribute from Lucide's <path> elements.

export global LucidePaths {
    out property <string> check:          "M 4 12 L 10 18 L 20 6";
    out property <string> x-mark:         "M 18 6 L 6 18 M 6 6 L 18 18";
    out property <string> chevron-down:   "M 6 9 L 12 15 L 18 9";
    out property <string> chevron-up:     "M 6 15 L 12 9 L 18 15";
    out property <string> chevron-right:  "M 9 6 L 15 12 L 9 18";
    out property <string> chevron-left:   "M 15 6 L 9 12 L 15 18";
    out property <string> plus:           "M 12 5 L 12 19 M 5 12 L 19 12";
    out property <string> minus:          "M 5 12 L 19 12";
    out property <string> arrow-right:    "M 5 12 L 19 12 M 13 6 L 19 12 L 13 18";
    out property <string> arrow-left:     "M 19 12 L 5 12 M 11 6 L 5 12 L 11 18";
    out property <string> dot:            "M 11 12 L 13 12";
}
