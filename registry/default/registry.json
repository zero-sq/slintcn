{
  "$schema": "https://slintcn.dev/schema/registry.json",
  "name": "default",
  "description": "Dark glass theme — shadcn-adjacent primitives for Slint",
  "slintVersion": ">=1.16",
  "theme": {
    "files": ["theme/palette.slint", "theme/tokens.slint"]
  },
  "components": {
    "button": {
      "files": ["components/button.slint"],
      "requires": ["theme"]
    },
    "card": {
      "files": ["components/card.slint"],
      "requires": ["theme"]
    },
    "input": {
      "files": ["components/input.slint"],
      "requires": ["theme"]
    },
    "badge": {
      "files": ["components/badge.slint"],
      "requires": ["theme"]
    },
    "separator": {
      "files": ["components/separator.slint"],
      "requires": ["theme"]
    },
    "label": {
      "files": ["components/label.slint"],
      "requires": ["theme"]
    },
    "popup-helpers": {
      "files": ["components/popup-helpers.slint"],
      "requires": ["theme"]
    },
    "dialog": {
      "files": ["components/dialog.slint"],
      "requires": ["theme", "popup-helpers", "button", "separator"]
    },
    "alert-dialog": {
      "files": ["components/alert-dialog.slint"],
      "requires": ["theme", "popup-helpers", "button", "separator"]
    },
    "sheet": {
      "files": ["components/sheet.slint"],
      "requires": ["theme", "popup-helpers"]
    },
    "tooltip": {
      "files": ["components/tooltip.slint"],
      "requires": ["theme"]
    },
    "toast": {
      "files": ["components/toast.slint"],
      "requires": ["theme"]
    },
    "tabs": {
      "files": ["components/tabs.slint"],
      "requires": ["theme"]
    },
    "checkbox": {
      "files": ["components/checkbox.slint"],
      "requires": ["theme"]
    },
    "switch": {
      "files": ["components/switch.slint"],
      "requires": ["theme"]
    },
    "icon": {
      "files": ["components/icon.slint"],
      "requires": ["theme"]
    },
    "lucide-paths": {
      "files": ["components/lucide-paths.slint"],
      "requires": []
    },
    "radio-group": {
      "files": ["components/radio-group.slint"],
      "requires": ["theme"]
    },
    "select": {
      "files": ["components/select.slint"],
      "requires": ["theme", "icon", "lucide-paths"]
    }
  }
}
