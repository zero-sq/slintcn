// slintcn palette — STONE base color (warm gray, brown-tinted).
// Installed as palette.slint when slintcn.json baseColor is "stone".
// Only the neutral scale differs from the default; accents + alphas match.

export global Palette {
    out property <color> neutral-50:  #fafaf9;
    out property <color> neutral-100: #f5f5f4;
    out property <color> neutral-200: #e7e5e4;
    out property <color> neutral-300: #d6d3d1;
    out property <color> neutral-400: #a8a29e;
    out property <color> neutral-500: #78716c;
    out property <color> neutral-600: #57534e;
    out property <color> neutral-700: #44403c;
    out property <color> neutral-800: #292524;
    out property <color> neutral-900: #1c1917;
    out property <color> neutral-950: #0c0a09;

    out property <color> red-400:   #ff6467;
    out property <color> green-400: #4ade80;

    out property <color> alpha-w-04: rgba(255, 255, 255, 0.04);
    out property <color> alpha-w-08: rgba(255, 255, 255, 0.08);
    out property <color> alpha-w-10: rgba(255, 255, 255, 0.10);
    out property <color> alpha-w-12: rgba(255, 255, 255, 0.12);
    out property <color> alpha-w-20: rgba(255, 255, 255, 0.20);
    out property <color> alpha-w-25: rgba(255, 255, 255, 0.25);
    out property <color> alpha-w-35: rgba(255, 255, 255, 0.35);
    out property <color> alpha-b-30: rgba(0, 0, 0, 0.30);
    out property <color> alpha-b-32: rgba(0, 0, 0, 0.32);
    out property <color> alpha-b-38: rgba(0, 0, 0, 0.38);
    out property <color> alpha-b-45: rgba(0, 0, 0, 0.45);
    out property <color> alpha-b-60: rgba(0, 0, 0, 0.60);

    out property <color> alpha-b-04-on-light: rgba(0, 0, 0, 0.04);
    out property <color> alpha-b-08-on-light: rgba(0, 0, 0, 0.08);
    out property <color> alpha-b-10-on-light: rgba(0, 0, 0, 0.10);
    out property <color> alpha-b-12-on-light: rgba(0, 0, 0, 0.12);
    out property <color> alpha-b-20-on-light: rgba(0, 0, 0, 0.20);
}
