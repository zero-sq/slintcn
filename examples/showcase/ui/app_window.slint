// slintcn showcase — shadcn/ui-docs-style layout.
//
// Sidebar (left, fixed) navigates between sections. Main content area
// shows the active section. Overlays (Dialog/AlertDialog/Sheet) and the
// Toaster mount at Window root so they're available from any section.
//
// Imports use the generated layout under ui/slintcn/ — produced by the
// `slintcn add …` invocation in build.rs.

import { Tokens, Theme, ThemeMode }             from "slintcn/theme/tokens.slint";
import { Palette }                              from "slintcn/theme/palette.slint";
import { Button, ButtonVariant, ButtonSize }    from "slintcn/components/button.slint";
import { Card, CardVariant, CardPadding, CardRadius } from "slintcn/components/card.slint";
import { Input }                                from "slintcn/components/input.slint";
import { Badge, BadgeVariant, BadgeSize }       from "slintcn/components/badge.slint";
import { Separator, SeparatorOrientation }      from "slintcn/components/separator.slint";
import { Label, LabelVariant }                  from "slintcn/components/label.slint";
import { Dialog }                               from "slintcn/components/dialog.slint";
import { AlertDialog }                          from "slintcn/components/alert-dialog.slint";
import { Sheet, SheetSide }                     from "slintcn/components/sheet.slint";
import { Tooltip, TooltipSide }                 from "slintcn/components/tooltip.slint";
import { Toaster, ToastQueue, ToastVariant, ToastItem } from "slintcn/components/toast.slint";

// Re-export so include_modules!() exposes them to Rust glue in main.rs.
export { ToastQueue, ToastVariant, ToastItem }
import { Tabs, TabItem }                        from "slintcn/components/tabs.slint";
import { Checkbox }                             from "slintcn/components/checkbox.slint";
import { Switch }                               from "slintcn/components/switch.slint";
import { RadioGroup, RadioItem, RadioOrientation } from "slintcn/components/radio-group.slint";
import { Select, SelectItem }                   from "slintcn/components/select.slint";
import { Icon }                                 from "slintcn/components/icon.slint";
import { LucidePaths }                          from "slintcn/components/lucide-paths.slint";
import { Progress }                             from "slintcn/components/progress.slint";
import { Skeleton }                             from "slintcn/components/skeleton.slint";
import { Avatar }                               from "slintcn/components/avatar.slint";
import { Alert, AlertVariant }                  from "slintcn/components/alert.slint";
import { Textarea }                             from "slintcn/components/textarea.slint";
import { Toggle, ToggleVariant }                from "slintcn/components/toggle.slint";
import { ToggleGroup, ToggleGroupItem }         from "slintcn/components/toggle-group.slint";
import { Accordion, AccordionItem }             from "slintcn/components/accordion.slint";
import { Slider }                               from "slintcn/components/slider.slint";
import { Breadcrumb, BreadcrumbItem }           from "slintcn/components/breadcrumb.slint";
import { Pagination }                           from "slintcn/components/pagination.slint";
import { Table, TableRow }                      from "slintcn/components/table.slint";
import { Text as Typography, TextVariant, TextTone } from "slintcn/components/text.slint";
import { Keycap, KeycapSize, KeycapTone }       from "slintcn/components/keycap.slint";
import { HudPill, HudPillSize, HudPillTone }    from "slintcn/components/hud-pill.slint";
import { SlotTile, SlotTileTone, SlotTileState } from "slintcn/components/slot-tile.slint";
import { TabsVariant }                          from "slintcn/components/tabs.slint";
import { ScrollArea }                           from "slintcn/components/scroll-area.slint";
import { Popover }                              from "slintcn/components/popover.slint";
import { ContextMenu, ContextMenuItemData }     from "slintcn/components/context-menu.slint";
import { SignIn }                               from "slintcn/blocks/sign-in.slint";
import { Login }                                from "slintcn/blocks/login.slint";
import { Pricing }                              from "slintcn/blocks/pricing.slint";
import { Dashboard as DashboardBlock }          from "slintcn/blocks/dashboard.slint";
import { Settings as SettingsBlock }            from "slintcn/blocks/settings.slint";

// Sidebar nav item — local helper, not part of the registry.
component NavItem inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked();

    height: 34px;
    background: active
        ? Tokens.color-surface-2
        : (touch.has-hover ? Tokens.color-surface-1 : transparent);
    border-radius: Tokens.radius-sm;

    Text {
        x: 12px;
        y: (parent.height - self.preferred-height) / 2;
        text: root.label;
        color: active
            ? Tokens.color-foreground
            : Tokens.color-muted-foreground;
        font-size: Tokens.typography-body-size;
        font-weight: active
            ? Tokens.typography-weight-semibold
            : Tokens.typography-weight-medium;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    animate background {
        duration: Tokens.motion-fast;
        easing: Tokens.motion-easing-standard;
    }
}

// Section heading (consistent typography across sections).
component SectionHeading inherits VerticalLayout {
    in property <string> title;
    in property <string> subtitle;
    spacing: 6px;

    Text {
        text: root.title;
        color: Tokens.color-foreground;
        font-size: Tokens.typography-h1-size;
        font-weight: Tokens.typography-weight-semibold;
    }
    if root.subtitle != "": Text {
        text: root.subtitle;
        color: Tokens.color-muted-foreground;
        font-size: Tokens.typography-body-size;
    }
}

export component AppWindow inherits Window {
    title: "slintcn showcase";
    preferred-width:  1100px;
    preferred-height: 760px;
    background: Tokens.color-background;

    in-out property <int>  active-section: 0;
    in-out property <bool> dialog-open: false;
    in-out property <bool> alert-open: false;
    in-out property <bool> sheet-open: false;
    in-out property <int>  plan-index: 1;
    in-out property <int>  size-radio: 1;
    in-out property <int>  density-radio: 1;
    in-out property <int>  settings-tab: 0;
    in-out property <int>  tabs-demo: 0;
    in-out property <bool> remember-me: true;
    in-out property <bool> setting-notifications: true;
    in-out property <bool> setting-marketing: false;
    in-out property <bool> setting-dark-mode: true;
    in-out property <int>  accordion-open: 0;
    in-out property <int>  align-toggle: 1;
    in-out property <bool> bold-toggle: true;
    in-out property <float> volume: 60;
    in-out property <int>  page-current: 2;

    HorizontalLayout {
        padding: Tokens.spacing-xl;
        spacing: Tokens.spacing-xl;

        // ─── Sidebar ─────────────────────────────────────────────────
        Rectangle {
            width: 220px;
            background: Tokens.color-card;
            border-color: Tokens.color-border-hairline;
            border-width: 1px;
            border-radius: Tokens.radius-xl;

            VerticalLayout {
                padding: 20px;
                spacing: 4px;
                alignment: start;

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Text {
                        text: "slintcn";
                        color: Tokens.color-foreground;
                        font-size: Tokens.typography-title-size;
                        font-weight: Tokens.typography-weight-semibold;
                    }
                    Badge {
                        text: "v0.16";
                        variant: BadgeVariant.secondary;
                        size: BadgeSize.sm;
                    }
                }

                Rectangle { height: 14px; background: transparent; }

                Label { text: "Components"; variant: LabelVariant.muted; }

                NavItem {
                    label: "Buttons";
                    active: root.active-section == 0;
                    clicked => { root.active-section = 0; }
                }
                NavItem {
                    label: "Form";
                    active: root.active-section == 1;
                    clicked => { root.active-section = 1; }
                }
                NavItem {
                    label: "Overlays";
                    active: root.active-section == 2;
                    clicked => { root.active-section = 2; }
                }
                NavItem {
                    label: "Tabs";
                    active: root.active-section == 3;
                    clicked => { root.active-section = 3; }
                }
                NavItem {
                    label: "Selection";
                    active: root.active-section == 7;
                    clicked => { root.active-section = 7; }
                }
                NavItem {
                    label: "Feedback";
                    active: root.active-section == 8;
                    clicked => { root.active-section = 8; }
                }
                NavItem {
                    label: "Display";
                    active: root.active-section == 9;
                    clicked => { root.active-section = 9; }
                }
                NavItem {
                    label: "Navigation";
                    active: root.active-section == 10;
                    clicked => { root.active-section = 10; }
                }
                NavItem {
                    label: "Data";
                    active: root.active-section == 11;
                    clicked => { root.active-section = 11; }
                }
                NavItem {
                    label: "Typography";
                    active: root.active-section == 12;
                    clicked => { root.active-section = 12; }
                }
                NavItem {
                    label: "HUD";
                    active: root.active-section == 13;
                    clicked => { root.active-section = 13; }
                }
                NavItem {
                    label: "Interaction";
                    active: root.active-section == 14;
                    clicked => { root.active-section = 14; }
                }
                NavItem {
                    label: "Blocks";
                    active: root.active-section == 15;
                    clicked => { root.active-section = 15; }
                }
                NavItem {
                    label: "Colors";
                    active: root.active-section == 16;
                    clicked => { root.active-section = 16; }
                }

                Rectangle { height: 12px; background: transparent; }

                Label { text: "Examples"; variant: LabelVariant.muted; }

                NavItem {
                    label: "Sign-in";
                    active: root.active-section == 4;
                    clicked => { root.active-section = 4; }
                }
                NavItem {
                    label: "Settings";
                    active: root.active-section == 5;
                    clicked => { root.active-section = 5; }
                }
                NavItem {
                    label: "Dashboard";
                    active: root.active-section == 6;
                    clicked => { root.active-section = 6; }
                }

                Rectangle {
                    background: transparent;
                    vertical-stretch: 1;
                }

                Separator { orientation: SeparatorOrientation.horizontal; }

                // Theme toggle — mutates Theme.mode reactively; every Tokens
                // binding across the app updates without a reload.
                Switch {
                    label: "Light mode";
                    checked: false;
                    toggled(v) => {
                        Theme.mode = v ? ThemeMode.light : ThemeMode.dark;
                    }
                }

                Text {
                    text: "Copy-paste UI for Slint";
                    color: Tokens.color-muted-foreground;
                    font-size: Tokens.typography-label-size;
                }
            }
        }

        // ─── Content area ────────────────────────────────────────────
        Rectangle {
            background: transparent;
            horizontal-stretch: 1;

            // (0) Buttons gallery
            if root.active-section == 0: VerticalLayout {
                spacing: 20px;
                alignment: start;

                SectionHeading {
                    title: "Buttons";
                    subtitle: "8 variants × 4 text sizes, plus 4 icon sizes. Enter / Space activate the focused button.";
                }

                Label { text: "Variants"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 8px;
                    Button { variant: ButtonVariant.default;     text: "Default"; }
                    Button { variant: ButtonVariant.secondary;   text: "Secondary"; }
                    Button { variant: ButtonVariant.outline;     text: "Outline"; }
                    Button { variant: ButtonVariant.ghost;       text: "Ghost"; }
                }
                HorizontalLayout {
                    spacing: 8px;
                    Button { variant: ButtonVariant.glass;       text: "Glass"; }
                    Button { variant: ButtonVariant.glow;        text: "Glow CTA"; }
                    Button { variant: ButtonVariant.destructive; text: "Destructive"; }
                    Button { variant: ButtonVariant.link;        text: "Link"; }
                }

                Label { text: "Sizes"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Button { variant: ButtonVariant.default; size: ButtonSize.xs;      text: "Extra small"; }
                    Button { variant: ButtonVariant.default; size: ButtonSize.sm;      text: "Small"; }
                    Button { variant: ButtonVariant.default; size: ButtonSize.default; text: "Default"; }
                    Button { variant: ButtonVariant.default; size: ButtonSize.lg;      text: "Large"; }
                }

                Label { text: "State"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Button { variant: ButtonVariant.default; text: "Enabled"; }
                    Button { variant: ButtonVariant.default; text: "Disabled"; disabled: true; }
                    Button { variant: ButtonVariant.destructive; text: "Destructive disabled"; disabled: true; }
                }
            }

            // (1) Form gallery
            if root.active-section == 1: VerticalLayout {
                spacing: 20px;
                alignment: start;

                SectionHeading {
                    title: "Form";
                    subtitle: "Input, Label, Checkbox, Switch, Badge — wired with a Card surface.";
                }

                Card {
                    variant: CardVariant.glass;
                    width: 100%;
                    height: 440px;

                    VerticalLayout {
                        padding: parent.padding-l;
                        spacing: parent.gap-l;

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            Label { text: "Sign up for the beta"; variant: LabelVariant.default; }
                            Badge { text: "v0.16"; variant: BadgeVariant.secondary; size: BadgeSize.sm; }
                        }

                        VerticalLayout {
                            spacing: 8px;
                            Label { text: "Email"; variant: LabelVariant.required; }
                            Input { width: 100%; placeholder: "you@example.com"; }
                        }
                        VerticalLayout {
                            spacing: 8px;
                            Label { text: "Password"; variant: LabelVariant.required; }
                            Input { width: 100%; placeholder: "••••••••"; password: true; }
                        }
                        VerticalLayout {
                            spacing: 8px;
                            Label { text: "Bio"; }
                            Textarea { width: 100%; placeholder: "Tell us about yourself…"; }
                        }

                        Separator { orientation: SeparatorOrientation.horizontal; }

                        HorizontalLayout {
                            spacing: Tokens.spacing-xl;
                            alignment: start;
                            Checkbox {
                                label: "Email me product updates";
                                checked <=> root.setting-notifications;
                            }
                            Switch {
                                label: "Dark mode";
                                checked <=> root.setting-dark-mode;
                            }
                        }
                    }
                }
            }

            // (2) Overlays gallery
            if root.active-section == 2: VerticalLayout {
                spacing: 20px;
                alignment: start;

                SectionHeading {
                    title: "Overlays";
                    subtitle: "Dialog · AlertDialog · Sheet · Tooltip · Toast — Escape closes modals.";
                }

                Label { text: "Modals"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Button {
                        variant: ButtonVariant.glow;
                        text: "Open Dialog";
                        clicked => { root.dialog-open = true; }
                    }
                    Button {
                        variant: ButtonVariant.destructive;
                        text: "Delete account";
                        clicked => { root.alert-open = true; }
                    }
                    Button {
                        variant: ButtonVariant.outline;
                        text: "Open Sheet (right)";
                        clicked => { root.sheet-open = true; }
                    }
                }

                Label { text: "Tooltip + Toast"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Tooltip {
                        text: "Hovers reveal me";
                        side: TooltipSide.top;
                        Button { variant: ButtonVariant.ghost; text: "Hover me"; }
                    }
                    Button {
                        variant: ButtonVariant.outline;
                        text: "Default toast";
                        clicked => { ToastQueue.show("Saved your changes.", ToastVariant.default); }
                    }
                    Button {
                        variant: ButtonVariant.outline;
                        text: "Success toast";
                        clicked => { ToastQueue.show("Profile updated.", ToastVariant.success); }
                    }
                    Button {
                        variant: ButtonVariant.outline;
                        text: "Error toast";
                        clicked => { ToastQueue.show("Network unreachable.", ToastVariant.error); }
                    }
                }
            }

            // (3) Tabs demo
            if root.active-section == 3: VerticalLayout {
                spacing: 20px;
                alignment: start;

                SectionHeading {
                    title: "Tabs";
                    subtitle: "Visual navigation strip. Consumer renders content per current index.";
                }

                // Wrap in alignment:start so the segmented strip sizes to its
                // content instead of stretching full-width.
                HorizontalLayout {
                    alignment: start;
                    Tabs {
                        items: [
                            { label: "Overview" },
                            { label: "Activity" },
                            { label: "Notifications" },
                        ];
                        current <=> root.tabs-demo;
                    }
                }

                Card {
                    variant: CardVariant.solid;
                    width: 100%;
                    height: 200px;

                    VerticalLayout {
                        padding: parent.padding-l;
                        spacing: parent.gap-l;

                        if root.tabs-demo == 0: VerticalLayout {
                            spacing: 6px;
                            Label { text: "Overview"; }
                            Text {
                                text: "Tabs is a visual strip. Render content yourself with `if current == N`.";
                                color: Tokens.color-muted-foreground;
                                font-size: Tokens.typography-body-size;
                                wrap: word-wrap;
                            }
                        }
                        if root.tabs-demo == 1: VerticalLayout {
                            spacing: 6px;
                            Label { text: "Activity"; }
                            Text {
                                text: "Each tab triggers a render swap reactively. No content state is lost between switches.";
                                color: Tokens.color-muted-foreground;
                                font-size: Tokens.typography-body-size;
                                wrap: word-wrap;
                            }
                        }
                        if root.tabs-demo == 2: VerticalLayout {
                            spacing: 6px;
                            Label { text: "Notifications"; }
                            Text {
                                text: "Keyboard: Tab focuses a trigger, Enter / Space activates it.";
                                color: Tokens.color-muted-foreground;
                                font-size: Tokens.typography-body-size;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }

            // (4) Sign-in composed example
            if root.active-section == 4: VerticalLayout {
                spacing: 20px;
                alignment: start;

                SectionHeading {
                    title: "Sign-in";
                    subtitle: "Card + Label + Input + Checkbox + Button — a complete authentication surface.";
                }

                Rectangle {
                    background: transparent;
                    width: 100%;
                    height: 460px;

                    Card {
                        variant: CardVariant.raised;
                        width: 380px;
                        height: 420px;
                        x: (parent.width - self.width) / 2;
                        y: 0;

                        VerticalLayout {
                            padding: parent.padding-l;
                            spacing: parent.gap-l;

                            VerticalLayout {
                                spacing: 6px;
                                Text {
                                    text: "Welcome back";
                                    color: Tokens.color-foreground;
                                    font-size: 22px;
                                    font-weight: Tokens.typography-weight-semibold;
                                }
                                Text {
                                    text: "Sign in to your slintcn account.";
                                    color: Tokens.color-muted-foreground;
                                    font-size: Tokens.typography-body-size;
                                }
                            }

                            VerticalLayout {
                                spacing: 8px;
                                Label { text: "Email"; variant: LabelVariant.required; }
                                Input { width: 100%; placeholder: "you@example.com"; }
                            }
                            VerticalLayout {
                                spacing: 8px;
                                Label { text: "Password"; variant: LabelVariant.required; }
                                Input { width: 100%; placeholder: "••••••••"; password: true; }
                            }

                            HorizontalLayout {
                                alignment: space-between;
                                Checkbox {
                                    label: "Remember me";
                                    checked <=> root.remember-me;
                                }
                                Button {
                                    variant: ButtonVariant.link;
                                    text: "Forgot password?";
                                }
                            }

                            Button {
                                variant: ButtonVariant.glow;
                                text: "Sign in";
                                size: ButtonSize.lg;
                                clicked => { ToastQueue.show("Signed in.", ToastVariant.success); }
                            }

                            HorizontalLayout {
                                alignment: center;
                                spacing: 4px;
                                Text {
                                    text: "Don't have an account?";
                                    color: Tokens.color-muted-foreground;
                                    font-size: Tokens.typography-body-size;
                                }
                                Button {
                                    variant: ButtonVariant.link;
                                    text: "Create one";
                                }
                            }
                        }
                    }
                }
            }

            // (5) Settings composed example
            if root.active-section == 5: VerticalLayout {
                spacing: 20px;
                alignment: start;

                SectionHeading {
                    title: "Settings";
                    subtitle: "Tabs + Inputs + Switches composed into a realistic preferences surface.";
                }

                HorizontalLayout {
                    alignment: start;
                    Tabs {
                        items: [
                            { label: "Account" },
                            { label: "Notifications" },
                            { label: "Appearance" },
                        ];
                        current <=> root.settings-tab;
                    }
                }

                Card {
                    variant: CardVariant.solid;
                    width: 100%;
                    height: 360px;

                    VerticalLayout {
                        padding: parent.padding-l;
                        spacing: parent.gap-l;

                        if root.settings-tab == 0: VerticalLayout {
                            spacing: 12px;
                            alignment: start;
                            Text {
                                text: "Profile";
                                color: Tokens.color-foreground;
                                font-size: 16px;
                                font-weight: Tokens.typography-weight-semibold;
                            }
                            VerticalLayout {
                                spacing: 6px;
                                Label { text: "Display name"; }
                                Input { width: 100%; placeholder: "Steve Kwon"; }
                            }
                            VerticalLayout {
                                spacing: 6px;
                                Label { text: "Email"; variant: LabelVariant.required; }
                                Input { width: 100%; placeholder: "you@example.com"; }
                            }
                            HorizontalLayout {
                                alignment: end;
                                Button {
                                    variant: ButtonVariant.default;
                                    text: "Save changes";
                                    clicked => { ToastQueue.show("Profile saved.", ToastVariant.success); }
                                }
                            }
                        }

                        if root.settings-tab == 1: VerticalLayout {
                            spacing: 14px;
                            alignment: start;
                            Text {
                                text: "Email";
                                color: Tokens.color-foreground;
                                font-size: 16px;
                                font-weight: Tokens.typography-weight-semibold;
                            }
                            Switch {
                                label: "Product updates";
                                checked <=> root.setting-notifications;
                            }
                            Switch {
                                label: "Weekly digest";
                                checked <=> root.setting-marketing;
                            }
                            Separator { orientation: SeparatorOrientation.horizontal; }
                            Text {
                                text: "Push";
                                color: Tokens.color-foreground;
                                font-size: 16px;
                                font-weight: Tokens.typography-weight-semibold;
                            }
                            Checkbox { label: "Mentions and replies"; checked: true; }
                            Checkbox { label: "Marketing"; checked: false; }
                        }

                        if root.settings-tab == 2: VerticalLayout {
                            spacing: 14px;
                            alignment: start;
                            Text {
                                text: "Theme";
                                color: Tokens.color-foreground;
                                font-size: 16px;
                                font-weight: Tokens.typography-weight-semibold;
                            }
                            Switch {
                                label: "Dark mode";
                                checked <=> root.setting-dark-mode;
                            }
                            Separator { orientation: SeparatorOrientation.horizontal; }
                            Text {
                                text: "Density";
                                color: Tokens.color-foreground;
                                font-size: 16px;
                                font-weight: Tokens.typography-weight-semibold;
                            }
                            Text {
                                text: "Density controls land in v0.4 once RadioGroup ships.";
                                color: Tokens.color-muted-foreground;
                                font-size: Tokens.typography-body-size;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }

            // (6) Dashboard composed example
            if root.active-section == 6: VerticalLayout {
                spacing: 20px;
                alignment: start;

                SectionHeading {
                    title: "Dashboard";
                    subtitle: "Metric cards + activity feed using Card, Badge, Separator, Label.";
                }

                HorizontalLayout {
                    spacing: 16px;
                    alignment: stretch;

                    Card {
                        variant: CardVariant.raised;
                        width: 32%;
                        height: 120px;
                        VerticalLayout {
                            padding: parent.padding-l;
                            spacing: 6px;
                            alignment: start;
                            Label { text: "Revenue"; variant: LabelVariant.muted; }
                            Text {
                                text: "$ 42,580";
                                color: Tokens.color-foreground;
                                font-size: 26px;
                                font-weight: Tokens.typography-weight-semibold;
                            }
                            Badge { text: "+12.4% MoM"; variant: BadgeVariant.default; size: BadgeSize.sm; }
                        }
                    }
                    Card {
                        variant: CardVariant.raised;
                        width: 32%;
                        height: 120px;
                        VerticalLayout {
                            padding: parent.padding-l;
                            spacing: 6px;
                            alignment: start;
                            Label { text: "Active users"; variant: LabelVariant.muted; }
                            Text {
                                text: "1,284";
                                color: Tokens.color-foreground;
                                font-size: 26px;
                                font-weight: Tokens.typography-weight-semibold;
                            }
                            Badge { text: "+3.1% WoW"; variant: BadgeVariant.secondary; size: BadgeSize.sm; }
                        }
                    }
                    Card {
                        variant: CardVariant.raised;
                        width: 32%;
                        height: 120px;
                        VerticalLayout {
                            padding: parent.padding-l;
                            spacing: 6px;
                            alignment: start;
                            Label { text: "Bounce rate"; variant: LabelVariant.muted; }
                            Text {
                                text: "27.8%";
                                color: Tokens.color-foreground;
                                font-size: 26px;
                                font-weight: Tokens.typography-weight-semibold;
                            }
                            Badge { text: "−1.4% MoM"; variant: BadgeVariant.destructive; size: BadgeSize.sm; }
                        }
                    }
                }

                Card {
                    variant: CardVariant.solid;
                    width: 100%;
                    height: 240px;

                    VerticalLayout {
                        padding: parent.padding-l;
                        spacing: parent.gap-l;

                        HorizontalLayout {
                            alignment: space-between;
                            Label { text: "Recent activity"; }
                            Button { variant: ButtonVariant.link; text: "View all"; }
                        }
                        Separator { orientation: SeparatorOrientation.horizontal; }

                        HorizontalLayout {
                            spacing: 12px;
                            alignment: start;
                            Badge { text: "DEPLOY"; variant: BadgeVariant.default; size: BadgeSize.sm; }
                            Text {
                                text: "Production deploy succeeded";
                                color: Tokens.color-foreground;
                                font-size: Tokens.typography-body-size;
                                vertical-alignment: center;
                            }
                            Rectangle { horizontal-stretch: 1; background: transparent; }
                            Text {
                                text: "2m ago";
                                color: Tokens.color-muted-foreground;
                                font-size: Tokens.typography-body-sm-size;
                                vertical-alignment: center;
                            }
                        }
                        HorizontalLayout {
                            spacing: 12px;
                            alignment: start;
                            Badge { text: "USER"; variant: BadgeVariant.secondary; size: BadgeSize.sm; }
                            Text {
                                text: "12 new sign-ups in the last hour";
                                color: Tokens.color-foreground;
                                font-size: Tokens.typography-body-size;
                                vertical-alignment: center;
                            }
                            Rectangle { horizontal-stretch: 1; background: transparent; }
                            Text {
                                text: "14m ago";
                                color: Tokens.color-muted-foreground;
                                font-size: Tokens.typography-body-sm-size;
                                vertical-alignment: center;
                            }
                        }
                        HorizontalLayout {
                            spacing: 12px;
                            alignment: start;
                            Badge { text: "ALERT"; variant: BadgeVariant.destructive; size: BadgeSize.sm; }
                            Text {
                                text: "API latency spike — 99p over 800 ms";
                                color: Tokens.color-foreground;
                                font-size: Tokens.typography-body-size;
                                vertical-alignment: center;
                            }
                            Rectangle { horizontal-stretch: 1; background: transparent; }
                            Text {
                                text: "1h ago";
                                color: Tokens.color-muted-foreground;
                                font-size: Tokens.typography-body-sm-size;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            // (7) Selection primitives — RadioGroup, Select, Icon
            if root.active-section == 7: VerticalLayout {
                spacing: 20px;
                alignment: start;

                SectionHeading {
                    title: "Selection";
                    subtitle: "RadioGroup, Select (in-tree dropdown), and the Icon helper with Lucide-compatible path data.";
                }

                Card {
                    variant: CardVariant.solid;
                    width: 100%;
                    height: 230px;

                    VerticalLayout {
                        padding: parent.padding-l;
                        spacing: parent.gap-l;

                        Label { text: "Pick a plan"; variant: LabelVariant.default; }

                        HorizontalLayout {
                            spacing: Tokens.spacing-2xl;
                            alignment: start;

                            VerticalLayout {
                                spacing: 8px;
                                alignment: start;
                                Label { text: "Tier"; variant: LabelVariant.muted; }
                                RadioGroup {
                                    items: [
                                        { value: "free", label: "Free" },
                                        { value: "pro",  label: "Pro" },
                                        { value: "team", label: "Team" },
                                    ];
                                    selected <=> root.size-radio;
                                    changed(i) => {
                                        ToastQueue.show("Tier changed.", ToastVariant.default);
                                    }
                                }
                            }

                            VerticalLayout {
                                spacing: 8px;
                                alignment: start;
                                Label { text: "Billing"; variant: LabelVariant.muted; }
                                Select {
                                    items: [
                                        { value: "monthly", label: "Monthly" },
                                        { value: "yearly",  label: "Yearly (-20%)" },
                                        { value: "lifetime", label: "Lifetime" },
                                    ];
                                    selected-index <=> root.plan-index;
                                    placeholder: "Choose billing…";
                                    changed(i) => {
                                        ToastQueue.show("Billing updated.", ToastVariant.success);
                                    }
                                }
                            }
                        }
                    }
                }

                Card {
                    variant: CardVariant.glass;
                    width: 100%;
                    height: 160px;

                    VerticalLayout {
                        padding: parent.padding-l;
                        spacing: 8px;

                        Label { text: "Density (horizontal RadioGroup, ← / → to move)"; variant: LabelVariant.muted; }
                        RadioGroup {
                            items: [
                                { value: "compact",  label: "Compact" },
                                { value: "default",  label: "Default" },
                                { value: "spacious", label: "Spacious" },
                            ];
                            selected <=> root.density-radio;
                            orientation: RadioOrientation.horizontal;
                            changed(i) => {
                                ToastQueue.show("Density updated.", ToastVariant.default);
                            }
                        }

                        Label { text: "Icons"; variant: LabelVariant.muted; }
                        HorizontalLayout {
                            spacing: 14px;
                            alignment: start;
                            Icon { commands: LucidePaths.check;          tint: Tokens.color-foreground; size: 20px; }
                            Icon { commands: LucidePaths.x-mark;         tint: Tokens.color-foreground; size: 20px; }
                            Icon { commands: LucidePaths.chevron-down;   tint: Tokens.color-foreground; size: 20px; }
                            Icon { commands: LucidePaths.chevron-right;  tint: Tokens.color-foreground; size: 20px; }
                            Icon { commands: LucidePaths.plus;           tint: Tokens.color-foreground; size: 20px; }
                            Icon { commands: LucidePaths.minus;          tint: Tokens.color-foreground; size: 20px; }
                            Icon { commands: LucidePaths.arrow-right;    tint: Tokens.color-foreground; size: 20px; }
                            Icon { commands: LucidePaths.arrow-left;     tint: Tokens.color-destructive; size: 20px; }
                        }
                    }
                }
            }

            // (8) Feedback — Alert, Progress, Skeleton
            if root.active-section == 8: VerticalLayout {
                spacing: Tokens.spacing-lg;
                alignment: start;

                SectionHeading {
                    title: "Feedback";
                    subtitle: "Alert, Progress, and Skeleton — status and loading states.";
                }

                Alert {
                    width: 100%;
                    icon: LucidePaths.check;
                    title: "Deployed successfully";
                    description: "Your changes are live on production.";
                }
                Alert {
                    width: 100%;
                    variant: AlertVariant.destructive;
                    icon: LucidePaths.x-mark;
                    title: "Build failed";
                    description: "3 type errors in engine-mount.tsx. Check the logs.";
                }

                Label { text: "Progress"; variant: LabelVariant.muted; }
                Progress { width: 100%; value: 28; }
                Progress { width: 100%; value: 64; }

                Label { text: "Skeleton (loading)"; variant: LabelVariant.muted; }
                VerticalLayout {
                    spacing: 8px;
                    Skeleton { width: 60%; height: 16px; }
                    Skeleton { width: 90%; height: 16px; }
                    Skeleton { width: 75%; height: 16px; }
                }
            }

            // (9) Display — Avatar, Accordion, Toggle, ToggleGroup
            if root.active-section == 9: VerticalLayout {
                spacing: Tokens.spacing-lg;
                alignment: start;

                SectionHeading {
                    title: "Display";
                    subtitle: "Avatar, Accordion, Toggle, and ToggleGroup.";
                }

                Label { text: "Avatars"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    Avatar { fallback: "SK"; size: 32px; }
                    Avatar { fallback: "AB"; size: 40px; }
                    Avatar { fallback: "CD"; size: 56px; }
                }

                Label { text: "Toggles"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    Toggle { text: "Bold"; pressed <=> root.bold-toggle; }
                    Toggle { text: "Italic"; variant: ToggleVariant.outline; }
                    ToggleGroup {
                        items: [{ label: "Left" }, { label: "Center" }, { label: "Right" }];
                        selected <=> root.align-toggle;
                    }
                }

                Label { text: "Accordion"; variant: LabelVariant.muted; }
                Card {
                    variant: CardVariant.solid;
                    width: 100%;
                    height: 260px;
                    VerticalLayout {
                        padding: parent.padding-l;
                        Accordion {
                            open-index <=> root.accordion-open;
                            items: [
                                { title: "Is it accessible?", content: "Yes. Enter / Space toggle, arrow keys navigate where applicable." },
                                { title: "Is it styled?", content: "It uses the slintcn token system — dark glass by default, light via Theme.mode." },
                                { title: "Is it animated?", content: "Content height animates on expand/collapse using the motion-base duration." },
                            ];
                        }
                    }
                }
            }

            // (10) Navigation — Breadcrumb, Pagination, Slider
            if root.active-section == 10: VerticalLayout {
                spacing: Tokens.spacing-lg;
                alignment: start;

                SectionHeading {
                    title: "Navigation";
                    subtitle: "Breadcrumb, Pagination, and Slider.";
                }

                Label { text: "Breadcrumb"; variant: LabelVariant.muted; }
                Breadcrumb {
                    items: [
                        { label: "Home" },
                        { label: "Components" },
                        { label: "Navigation" },
                    ];
                    navigate(i) => { ToastQueue.show("Navigate to crumb \{i}", ToastVariant.default); }
                }

                Label { text: "Pagination"; variant: LabelVariant.muted; }
                Pagination {
                    total: 5;
                    current <=> root.page-current;
                    changed(p) => { ToastQueue.show("Page \{p + 1}", ToastVariant.default); }
                }

                Label { text: "Slider (volume)"; variant: LabelVariant.muted; }
                Slider {
                    width: 320px;
                    value <=> root.volume;
                }
            }

            // (11) Data — Table
            if root.active-section == 11: VerticalLayout {
                spacing: Tokens.spacing-lg;
                alignment: start;

                SectionHeading {
                    title: "Data";
                    subtitle: "Table — header + rows aligned by equal-stretch columns.";
                }

                Card {
                    variant: CardVariant.solid;
                    width: 100%;
                    height: 280px;
                    VerticalLayout {
                        padding: parent.padding-l;
                        Table {
                            columns: ["Invoice", "Status", "Method", "Amount"];
                            rows: [
                                { cells: ["INV-001", "Paid", "Card", "$ 250.00"] },
                                { cells: ["INV-002", "Pending", "Transfer", "$ 1,200.00"] },
                                { cells: ["INV-003", "Paid", "Card", "$ 84.00"] },
                                { cells: ["INV-004", "Overdue", "PayPal", "$ 540.00"] },
                            ];
                        }
                    }
                }
            }

            // (12) Typography — Text variants/tones + new variant axes
            if root.active-section == 12: VerticalLayout {
                spacing: Tokens.spacing-lg;
                alignment: start;

                SectionHeading {
                    title: "Typography";
                    subtitle: "Text variant × tone scale, plus the new Badge / Tabs / Card variant axes.";
                }

                Typography { text: "Display — 36"; variant: TextVariant.display; }
                Typography { text: "Headline — 30"; variant: TextVariant.headline; }
                Typography { text: "Title — 20"; variant: TextVariant.title; }
                Typography { text: "Body large — 16"; variant: TextVariant.body-lg; }
                Typography { text: "Body — 14"; variant: TextVariant.body; }
                Typography { text: "Caption — 11"; variant: TextVariant.caption; tone: TextTone.muted; }

                Label { text: "Tones"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 20px;
                    alignment: start;
                    Typography { text: "default"; tone: TextTone.default; }
                    Typography { text: "muted";   tone: TextTone.muted; }
                    Typography { text: "subtle";  tone: TextTone.subtle; }
                    Typography { text: "accent";  tone: TextTone.accent; }
                    Typography { text: "danger";  tone: TextTone.danger; }
                }

                Label { text: "Badge ghost / link  ·  Tabs line variant"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    Badge { text: "ghost"; variant: BadgeVariant.ghost; }
                    Badge { text: "link"; variant: BadgeVariant.link; }
                }
                HorizontalLayout {
                    alignment: start;
                    Tabs {
                        variant: TabsVariant.line;
                        items: [{ label: "Overview" }, { label: "Activity" }, { label: "Settings" }];
                    }
                }

                Label { text: "Card padding / radius axes"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    Card {
                        card-padding: CardPadding.sm;
                        card-radius: CardRadius.md;
                        width: 150px; height: 70px;
                        VerticalLayout {
                            padding: parent.padding-l;
                            Typography { text: "pad sm · rad md"; variant: TextVariant.body-sm; tone: TextTone.muted; }
                        }
                    }
                    Card {
                        card-padding: CardPadding.lg;
                        card-radius: CardRadius.xxl;
                        width: 150px; height: 70px;
                        VerticalLayout {
                            padding: parent.padding-l;
                            Typography { text: "pad lg · rad 2xl"; variant: TextVariant.body-sm; tone: TextTone.muted; }
                        }
                    }
                }
            }

            // (13) HUD — Keycap, HudPill, SlotTile (Slint for games + tools)
            if root.active-section == 13: VerticalLayout {
                spacing: Tokens.spacing-lg;
                alignment: start;

                SectionHeading {
                    title: "HUD";
                    subtitle: "Keycap, HudPill, SlotTile — the games + tools layer.";
                }

                Label { text: "Keycap (tones)"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Keycap { text: "⌘"; tone: KeycapTone.on-glass; }
                    Keycap { text: "K"; tone: KeycapTone.on-glow; }
                    Keycap { text: "Esc"; tone: KeycapTone.muted; }
                    Keycap { text: "↵"; tone: KeycapTone.affirm-on-glass; }
                    Keycap { text: "⌫"; tone: KeycapTone.deny-on-glass; }
                    Keycap { text: "W"; size: KeycapSize.sm; tone: KeycapTone.on-glass; }
                }

                Label { text: "HudPill (scrim levels × sizes)"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    HudPill { text: "120 FPS"; size: HudPillSize.sm; tone: HudPillTone.scrim0; }
                    HudPill { text: "Wave 3 / 8"; tone: HudPillTone.scrim1; }
                    HudPill { text: "● REC"; size: HudPillSize.lg; tone: HudPillTone.scrim2; }
                }

                Label { text: "SlotTile (hotbar)"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    SlotTile {
                        tone: SlotTileTone.stone;
                        state: SlotTileState.active;
                        interactive: true;
                        Keycap { x: 4px; y: 4px; text: "1"; size: KeycapSize.sm; tone: KeycapTone.on-glass; }
                    }
                    SlotTile { tone: SlotTileTone.stone; interactive: true; }
                    SlotTile { tone: SlotTileTone.accent; interactive: true; }
                    SlotTile { tone: SlotTileTone.empty; }
                    SlotTile { tone: SlotTileTone.stone; state: SlotTileState.disabled; }
                }
            }

            // (14) Interaction — ScrollArea, Popover, ContextMenu
            if root.active-section == 14: VerticalLayout {
                spacing: Tokens.spacing-lg;
                alignment: start;

                SectionHeading {
                    title: "Interaction";
                    subtitle: "ScrollArea, Popover, and ContextMenu — overlay + scroll behaviors.";
                }

                Label { text: "Popover (click) · ContextMenu (right-click)"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;

                    Popover {
                        title: "Quick settings";
                        description: "A click-triggered floating panel. Click outside to dismiss.";
                        Button { text: "Open popover"; variant: ButtonVariant.outline; }
                    }

                    ContextMenu {
                        items: [
                            { label: "Cut" },
                            { label: "Copy" },
                            { label: "Paste" },
                            { label: "Delete" },
                        ];
                        selected(i) => { ToastQueue.show("Menu action \{i}", ToastVariant.default); }
                        Card {
                            card-padding: CardPadding.md;
                            width: 240px;
                            height: 56px;
                            VerticalLayout {
                                padding: parent.padding-l;
                                Typography {
                                    text: "Right-click anywhere here";
                                    variant: TextVariant.body-sm;
                                    tone: TextTone.muted;
                                }
                            }
                        }
                    }
                }

                Label { text: "ScrollArea"; variant: LabelVariant.muted; }
                Card {
                    variant: CardVariant.solid;
                    card-padding: CardPadding.none;
                    width: 360px;
                    height: 200px;
                    ScrollArea {
                        content-height: 520px;
                        VerticalLayout {
                            padding: Tokens.spacing-lg;
                            spacing: Tokens.spacing-md;
                            height: 520px;
                            for i in 12: HorizontalLayout {
                                spacing: 12px;
                                alignment: start;
                                Avatar { fallback: "U"; size: 28px; }
                                Typography {
                                    text: "Scrollable row — drag to scroll";
                                    variant: TextVariant.body;
                                }
                            }
                        }
                    }
                }
            }

            // (15) Blocks — composed templates installable via `slintcn add <name>`
            if root.active-section == 15: VerticalLayout {
                spacing: Tokens.spacing-lg;
                alignment: start;

                SectionHeading {
                    title: "Blocks";
                    subtitle: "Composed templates — `slintcn add sign-in · login · pricing · dashboard · settings`.";
                }

                HorizontalLayout {
                    spacing: 16px;
                    alignment: start;
                    SignIn {
                        submit => { ToastQueue.show("Signed in", ToastVariant.success); }
                        forgot => { ToastQueue.show("Reset link sent", ToastVariant.default); }
                    }
                    Login {
                        submit => { ToastQueue.show("Logged in", ToastVariant.success); }
                    }
                }

                Pricing {
                    pick(i) => { ToastQueue.show("Picked plan \{i}", ToastVariant.default); }
                }

                DashboardBlock { }

                SettingsBlock {
                    save => { ToastQueue.show("Settings saved", ToastVariant.success); }
                }
            }

            // (16) Colors — palette reference + base-color note
            if root.active-section == 16: VerticalLayout {
                spacing: Tokens.spacing-lg;
                alignment: start;

                SectionHeading {
                    title: "Colors";
                    subtitle: "Neutral ramp + accents. Switch hue at init: slintcn init --base-color zinc / slate / stone.";
                }

                Label { text: "Neutral scale"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 6px;
                    alignment: start;
                    for sw in [
                        { label: "50",  c: Palette.neutral-50 },
                        { label: "100", c: Palette.neutral-100 },
                        { label: "200", c: Palette.neutral-200 },
                        { label: "300", c: Palette.neutral-300 },
                        { label: "400", c: Palette.neutral-400 },
                        { label: "500", c: Palette.neutral-500 },
                        { label: "600", c: Palette.neutral-600 },
                        { label: "700", c: Palette.neutral-700 },
                        { label: "800", c: Palette.neutral-800 },
                        { label: "900", c: Palette.neutral-900 },
                        { label: "950", c: Palette.neutral-950 },
                    ]: VerticalLayout {
                        spacing: 4px;
                        Rectangle {
                            width: 56px;
                            height: 48px;
                            background: sw.c;
                            border-radius: Tokens.radius-md;
                            border-width: 1px;
                            border-color: Tokens.color-border-hairline;
                        }
                        Text {
                            text: sw.label;
                            color: Tokens.color-muted-foreground;
                            font-size: Tokens.typography-label-size;
                            horizontal-alignment: center;
                        }
                    }
                }

                Label { text: "Accents"; variant: LabelVariant.muted; }
                HorizontalLayout {
                    spacing: 6px;
                    alignment: start;
                    for sw in [
                        { label: "destructive", c: Tokens.color-destructive },
                        { label: "affirm", c: Tokens.color-affirm },
                        { label: "primary", c: Tokens.color-primary },
                    ]: VerticalLayout {
                        spacing: 4px;
                        Rectangle {
                            width: 96px;
                            height: 48px;
                            background: sw.c;
                            border-radius: Tokens.radius-md;
                        }
                        Text {
                            text: sw.label;
                            color: Tokens.color-muted-foreground;
                            font-size: Tokens.typography-label-size;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // ─── Window-level overlays — always mounted, last children. ─────
    Dialog {
        width: parent.width;
        height: parent.height;
        open <=> root.dialog-open;
        title: "Confirm your action";
        description: "This is a slintcn Dialog primitive. Press Escape or click the backdrop to dismiss.";
        close-label: "Got it";
    }

    AlertDialog {
        width: parent.width;
        height: parent.height;
        open <=> root.alert-open;
        title: "Delete this account?";
        description: "This action is permanent. All workspace data tied to the account will be removed.";
        action-label: "Delete";
        cancel-label: "Keep account";
    }

    Sheet {
        width: parent.width;
        height: parent.height;
        open <=> root.sheet-open;
        side: SheetSide.right;
        title: "Filters";
        description: "Adjust the visible content";
    }

    Toaster {
        width: parent.width;
        height: parent.height;
    }
}
